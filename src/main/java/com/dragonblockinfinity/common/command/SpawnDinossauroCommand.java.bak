package com.dragonblockinfinity.common.command;

import com.dragonblockinfinity.registry.ModEntities;
import com.dragonblockinfinity.common.entity.DinossauroEntity;
import com.mojang.brigadier.CommandDispatcher;
import com.mojang.brigadier.context.CommandContext;
import com.mojang.brigadier.exceptions.CommandSyntaxException;
import net.minecraft.commands.CommandSourceStack;
import net.minecraft.commands.Commands;
import net.minecraft.server.level.ServerLevel;
import net.minecraft.world.entity.EntityType;

public class SpawnDinossauroCommand {

    public static void register(CommandDispatcher<CommandSourceStack> dispatcher) {
        dispatcher.register(
            Commands.literal("spawndino")
                .requires(src -> src.hasPermission(2))
                .executes(ctx -> execute(ctx))
        );
    }

    private static int execute(CommandContext<CommandSourceStack> ctx) throws CommandSyntaxException {
        CommandSourceStack source = ctx.getSource();
        ServerLevel level = source.getLevel();

        @SuppressWarnings("unchecked")
        EntityType<DinossauroEntity> type = (EntityType<DinossauroEntity>) ModEntities.DINOSSAURO.get();
        DinossauroEntity dino = type.create(level);
        if (dino == null) {
            source.sendFailure(net.minecraft.network.chat.Component.literal("Falha ao criar Dinossauro"));
            return 0;
        }

        double x = source.getPosition().x;
        double y = source.getPosition().y;
        double z = source.getPosition().z;
        dino.moveTo(x, y, z, source.getRotation().y, source.getRotation().x);

        level.addFreshEntity(dino);
            source.sendSuccess(() -> net.minecraft.network.chat.Component.literal("Dinossauro spawnado"), true);
        return 1;
    }
}
